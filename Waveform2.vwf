<fnetlist_cmd>quartus_eda --write_settings_files=off --simulation --functional=on --flatten_buses=off --tool=modelsim_oem --format=verilog --output_directory="C:/Users/User/Documents/01-uni/SPRING 2024-25/Embedded/Embedded-project-25/simulation/qsim/" bitonic_sorter_25 -c bitonic_sorter_25</fnetlist_cmd>
